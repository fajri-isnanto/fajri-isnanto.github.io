---
export interface Props {
    title: string;
    vendor: string;
    description: string;
    badgeImage: string;
    verifyUrl: string;
    issueDate: string;
    expiration?: string;
    skills: string[];
    verified: boolean;
}

const {
    title, vendor, description, badgeImage,
    verifyUrl, issueDate, expiration, skills, verified,
} = Astro.props;

const ease = "cubic-bezier(.22,.61,.36,1)";
---

<style>
    .card-v1 {
        transition: transform 300ms cubic-bezier(.22,.61,.36,1), box-shadow 300ms cubic-bezier(.22,.61,.36,1);
    }
    .card-v1:hover {
        transform: translateY(-8px) scale(1.01);
        box-shadow: 0 28px 60px rgba(0,0,0,.14);
    }
    .badge-v1 {
        transition: transform 300ms cubic-bezier(.22,.61,.36,1);
    }
    .card-v1:hover .badge-v1 {
        transform: scale(1.05) rotate(-2deg);
    }
    .chip-v1 {
        transition: all 200ms ease;
    }
    .chip-v1:hover {
        background: #111827;
        color: #fff;
        transform: translateY(-2px);
    }
    .cta-arrow {
        transition: transform 300ms cubic-bezier(.22,.61,.36,1);
    }
    .card-v1:hover .cta-arrow {
        transform: translateX(4px);
    }
    .topo-bg {
        opacity: 0.03;
        pointer-events: none;
    }
</style>

<a href={verifyUrl} target="_blank" rel="noopener noreferrer"
   class="card-v1 block max-w-[760px] w-full bg-white rounded-[24px] border border-[#ECECEC] overflow-hidden relative"
   style="box-shadow: 0 10px 30px rgba(0,0,0,.08);">

    <!-- Accent top border -->
    <div class="h-1 bg-[#EE0000]"></div>

    <!-- Decorative topology background -->
    <div class="topo-bg absolute inset-0 overflow-hidden" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <circle cx="85%" cy="20%" r="2" fill="#9CA3AF"/>
            <circle cx="15%" cy="75%" r="1.5" fill="#9CA3AF"/>
            <circle cx="70%" cy="85%" r="1" fill="#9CA3AF"/>
            <circle cx="90%" cy="60%" r="2.5" fill="#D1D5DB"/>
            <line x1="70%" y1="20%" x2="85%" y2="20%" stroke="#E5E7EB" stroke-width="0.5"/>
            <line x1="15%" y1="60%" x2="15%" y2="75%" stroke="#E5E7EB" stroke-width="0.5"/>
            <line x1="70%" y1="40%" x2="70%" y2="85%" stroke="#E5E7EB" stroke-width="0.5"/>
            <line x1="85%" y1="20%" x2="90%" y2="60%" stroke="#E5E7EB" stroke-width="0.5"/>
        </svg>
    </div>

    <div class="flex flex-col md:flex-row gap-8 p-10 relative z-10">
        <!-- Badge column (35%) -->
        <div class="flex-shrink-0 w-full md:w-[35%] flex flex-col items-center gap-4">
            <div class="badge-v1 p-6 rounded-[20px] border border-[#ECECEC] bg-white"
                 style="box-shadow: 0 10px 30px rgba(0,0,0,.08);">
                <img src={badgeImage} alt={`${title} badge`}
                     class="w-28 h-28 object-contain" loading="lazy"/>
            </div>
            {verified && (
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[#ECFDF5] text-[#16A34A] text-xs font-semibold tracking-wide">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m0-5a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    VERIFIED
                </span>
            )}
        </div>

        <!-- Content column (65%) -->
        <div class="flex-1 flex flex-col gap-4">
            <p class="text-xs uppercase tracking-[.12em] text-[#EE0000] font-semibold">{vendor}</p>
            <h3 class="text-[34px] font-bold leading-[1.2] text-[#111827]">{title}</h3>
            <p class="text-base leading-[1.7] text-[#6B7280] line-clamp-2">{description}</p>

            <!-- Skill chips -->
            <div class="flex flex-wrap gap-2 mt-1">
                {skills.map((skill) => (
                    <span class="chip-v1 inline-flex items-center h-[38px] px-[14px] rounded-full border border-[#E5E7EB] text-sm text-[#6B7280] bg-white cursor-default">
                        {skill}
                    </span>
                ))}
            </div>

            <!-- Footer -->
            <div class="flex flex-wrap items-center gap-4 mt-4 pt-4 border-t border-[#ECECEC]">
                <span class="text-xs text-[#9CA3AF]">Issued {issueDate}</span>
                {expiration && <span class="text-xs text-[#9CA3AF]">· Expires {expiration}</span>}
                <span class="inline-flex items-center gap-2 h-[52px] px-6 rounded-[16px] border-2 border-[#EE0000] text-[#EE0000] text-sm font-semibold ml-auto
                             hover:bg-[rgba(238,0,0,.04)] transition-colors duration-200">
                    Verify on Credly
                    <svg class="cta-arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7m0 0H7m10 0v10"/>
                    </svg>
                </span>
            </div>
        </div>
    </div>
</a>
