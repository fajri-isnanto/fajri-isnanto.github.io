---
// astro imports
import {getCollection} from "astro:content";

// components imports
import ProjectCard from "./ProjectCard.astro";
import {buttonVariants} from "./ui/button";

const allProjects = (await getCollection('projects'))
    .filter((project) => !project.data.draft)
    .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const projects = allProjects.slice(0, 8);
---

<!--Grid section to show the projects in to columns -->
<>
    <div class="relative left-1/2 -translate-x-1/2 w-screen">
        <div class="max-w-7xl mx-auto px-4">
            <section class="mt-10">
                <div class="mb-4">
                    <h2 class="text-3xl font-bold mb-4">Projects</h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {
                        projects.map((project) => (
                                <ProjectCard
                                        id={project.id}
                                        title={project.data.title}
                                        summary={project.data.summary}
                                        tags={project.data.tags}
                                        cover={project.data.cover}
                                />
                        ))
                    }
                </div>
            </section>
        </div>
    </div>
    <div class="flex justify-center mt-10">
        <a href="/projects" class={buttonVariants({ variant: "default" }) + "text-n700 bg-primary-light dark:bg-primary-dark hover:bg-primary-hover-light dark:hover:bg-primary-hover-dark"}>
            See All Projects
        </a>
    </div>
</>



