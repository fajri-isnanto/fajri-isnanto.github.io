---
export interface Props {
    badgeImage: string;
    title: string;
    issuer: string;
    description: string;
    tags: string[];
    issuedDate: string;
    expiration?: string;
    verifyUrl: string;
}

const {
    badgeImage, title, issuer, description,
    tags, issuedDate, expiration = "No Expiration", verifyUrl,
} = Astro.props;
---

<a href={verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-card">
    <!-- Top red bar -->
    <div class="cert-card__bar"></div>

    <!-- Body: 2 columns - badge left, content right -->
    <div class="cert-card__body">
        <!-- Left: badge + verified pill -->
        <div class="cert-card__left">
            <img src={badgeImage} alt={`${title} badge`} class="cert-card__badge" loading="lazy" />
            <span class="cert-card__pill">
                <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12">
                    <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.4 7.4a1 1 0 01-1.4 0L3.3 9.5a1 1 0 111.4-1.4l3.9 3.9 6.7-6.7a1 1 0 011.4 0z" clip-rule="evenodd"/>
                </svg>
                VERIFIED
            </span>
        </div>

        <!-- Right: content -->
        <div class="cert-card__right">
            <h3 class="cert-card__title">{title}</h3>
            <div class="cert-card__divider"></div>
            <p class="cert-card__issuer">{issuer}</p>
            <p class="cert-card__desc">{description}</p>
            <div class="cert-card__tags">
                {tags.map((tag) => <span class="cert-card__tag">{tag}</span>)}
            </div>
        </div>
    </div>

    <!-- Divider -->
    <div class="cert-card__sep"></div>

    <!-- Footer: 3 columns - Issued | Expiration | Verify -->
    <div class="cert-card__footer">
        <span class="cert-card__meta-item">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
                <rect x="3" y="4" width="14" height="13" rx="2"/><path d="M3 8h14M7 2v4M13 2v4"/>
            </svg>
            Issued {issuedDate}
        </span>
        <span class="cert-card__meta-item">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
                <circle cx="10" cy="10" r="7"/><path d="M10 6v4l3 2"/>
            </svg>
            {expiration}
        </span>
        <span class="cert-card__verify">
            Verify on Credly
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
                <path d="M7 13L13 7M13 7H8M13 7v5"/>
            </svg>
        </span>
    </div>
</a>

<style>
    .cert-card {
        display: flex;
        flex-direction: column;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: transform 150ms ease, box-shadow 150ms ease;
        height: 100%;
    }
    .cert-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(0,0,0,.1);
    }

    .cert-card__bar {
        height: 4px;
        background: #ee0000;
        flex-shrink: 0;
    }

    /* Body: 2 columns */
    .cert-card__body {
        display: flex;
        gap: 16px;
        padding: 20px 20px 0 20px;
    }

    /* Left column: badge */
    .cert-card__left {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .cert-card__badge {
        width: 96px;
        height: auto;
        border-radius: 8px;
    }

    .cert-card__pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #e6f7ec;
        color: #1b9c4d;
        font-size: 11px;
        font-weight: 700;
        padding: 5px 10px;
        border-radius: 999px;
        white-space: nowrap;
    }

    /* Right column: content */
    .cert-card__right {
        flex: 1;
        min-width: 0;
    }

    .cert-card__title {
        font-size: 18px;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1.3;
        margin: 0 0 10px 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cert-card__divider {
        width: 28px;
        height: 3px;
        background: #ee0000;
        border-radius: 2px;
        margin-bottom: 8px;
    }

    .cert-card__issuer {
        color: #ee0000;
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        margin: 0 0 6px 0;
    }

    .cert-card__desc {
        color: #5a6169;
        font-size: 14.5px;
        line-height: 1.55;
        margin: 0 0 12px 0;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cert-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .cert-card__tag {
        display: inline-flex;
        align-items: center;
        border: 1px solid #e6e8eb;
        border-radius: 999px;
        padding: 6px 13px;
        font-size: 13px;
        color: #1a1a1a;
    }

    .cert-card__sep {
        border-top: 1px solid #e6e8eb;
        margin: 16px 20px 0 20px;
    }

    /* Footer: 3 columns */
    .cert-card__footer {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 12px;
        padding: 14px 20px 20px 20px;
        margin-top: auto;
        align-items: center;
    }

    .cert-card__meta-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: #ee0000;
        font-size: 13px;
        white-space: nowrap;
    }

    .cert-card__verify {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border: 1.5px solid #ee0000;
        color: #ee0000;
        font-weight: 700;
        font-size: 13px;
        padding: 8px 14px;
        border-radius: 10px;
        white-space: nowrap;
        transition: background 150ms ease, color 150ms ease;
    }

    .cert-card:hover .cert-card__verify {
        background: #ee0000;
        color: #fff;
    }
</style>
