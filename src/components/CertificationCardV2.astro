---
export interface Props {
    title: string;
    vendor: string;
    description: string;
    badgeImage: string;
    verifyUrl: string;
    issueDate: string;
    expiration?: string;
    skills: string[];
    verified: boolean;
    compact?: boolean;
}

const {
    title, vendor, description, badgeImage,
    verifyUrl, issueDate, expiration, skills, verified,
    compact = false,
} = Astro.props;

const skillIcons: Record<string, string> = {
    "Linux": "terminal", "RHEL": "server", "SELinux": "shield",
    "LVM": "hard-drive", "Troubleshooting": "bug", "OpenShift": "cloud",
    "Kubernetes": "container", "Containers": "box", "Operators": "cog",
    "Helm": "anchor", "Podman": "package", "Docker": "layers",
    "Registries": "database", "Automation": "zap", "Ansible": "play",
};
function skillIcon(skill: string): string { return skillIcons[skill] || "code"; }
---

<style>
    .card-v2 { transition: transform 300ms cubic-bezier(.22,.61,.36,1), box-shadow 300ms cubic-bezier(.22,.61,.36,1); }
    .card-v2:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,.12); }
    .badge-v2 { transition: transform 300ms cubic-bezier(.22,.61,.36,1); }
    .card-v2:hover .badge-v2 { transform: scale(1.05) rotate(-2deg); }
    .chip-v2 { transition: all 200ms ease; }
    .chip-v2:hover { background: #111827; color: #fff; transform: translateY(-2px); }
    .cta-arrow-v2 { transition: transform 300ms cubic-bezier(.22,.61,.36,1); }
    .card-v2:hover .cta-arrow-v2 { transform: translateX(4px); }
</style>

<a href={verifyUrl} target="_blank" rel="noopener noreferrer"
   class="card-v2 group block w-full bg-[#FFFFFF] rounded-[24px] border border-[#ECECEC] overflow-hidden relative"
   style="box-shadow: 0 10px 30px rgba(0,0,0,.08);">

    <div class="h-1 bg-[#EE0000]"></div>

    {compact ? (
        <!-- COMPACT: single column -->
        <div class="flex flex-col items-center gap-4 p-6 relative z-10">
            <div class="badge-v2 p-4 rounded-[16px] border border-[#ECECEC] bg-white"
                 style="box-shadow: 0 6px 20px rgba(0,0,0,.06);">
                <img src={badgeImage} alt={`${title} badge`} class="w-20 h-20 object-contain" loading="lazy"/>
            </div>
            {verified && (
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-[#ECFDF5] text-[#16A34A] text-[10px] font-bold tracking-widest uppercase">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m-6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Verified
                </span>
            )}
            <p class="text-[10px] uppercase tracking-[.12em] text-[#EE0000] font-bold">{vendor}</p>
            <h3 class="text-lg font-bold leading-tight text-[#111827] text-center">{title}</h3>
            <p class="text-xs leading-relaxed text-[#6B7280] line-clamp-2 text-center">{description}</p>
            <div class="flex flex-wrap justify-center gap-1.5">
                {skills.map((skill) => (
                    <span class="chip-v2 inline-flex items-center gap-1 h-[28px] px-2.5 rounded-full border border-[#E5E7EB] text-[11px] text-[#6B7280] bg-white cursor-default">
                        {skill}
                    </span>
                ))}
            </div>
            <div class="w-full pt-3 border-t border-[#ECECEC] flex items-center justify-between gap-2">
                <span class="text-[11px] text-[#9CA3AF]">Issued {issueDate}</span>
                <span class="inline-flex items-center gap-1.5 h-[36px] px-4 rounded-[12px] border-2 border-[#E5E7EB] text-[#111827] text-xs font-semibold hover:border-[#EE0000] hover:bg-[rgba(238,0,0,.04)] transition-colors">
                    Verify
                    <svg class="cta-arrow-v2 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7m0 0H7m10 0v10"/></svg>
                </span>
            </div>
        </div>
    ) : (
        <!-- FULL: two columns -->
        <div class="flex flex-col md:flex-row gap-8 p-10 md:p-[40px] relative z-10">
            <div class="flex-shrink-0 w-full md:w-[35%] flex flex-col items-center justify-center gap-4">
                <div class="badge-v2 p-6 rounded-[20px] border border-[#ECECEC] bg-white"
                     style="box-shadow: 0 10px 30px rgba(0,0,0,.08);">
                    <img src={badgeImage} alt={`${title} badge`} class="w-28 h-28 object-contain" loading="lazy"/>
                </div>
                {verified && (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#ECFDF5] text-[#16A34A] text-xs font-bold tracking-widest uppercase">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m-6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Verified
                    </span>
                )}
            </div>
            <div class="flex-1 flex flex-col gap-4 md:gap-[20px]">
                <p class="text-xs uppercase tracking-[.12em] text-[#EE0000] font-bold">{vendor}</p>
                <h3 class="text-[34px] font-bold leading-[1.2] text-[#111827] tracking-tight">{title}</h3>
                <p class="text-[16px] leading-[1.7] text-[#6B7280] line-clamp-2 max-w-[540px]">{description}</p>
                <div class="flex flex-wrap gap-2 mt-1">
                    {skills.map((skill) => (
                        <span class="chip-v2 inline-flex items-center gap-1.5 h-[38px] px-[14px] rounded-full border border-[#E5E7EB] text-sm text-[#6B7280] bg-white cursor-default">
                            <svg class="w-3.5 h-3.5 text-[#9CA3AF]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                                {skillIcon(skill) === "terminal" && '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>'}
                                {skillIcon(skill) === "shield" && '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>'}
                                {skillIcon(skill) === "bug" && '<path d="M8 2l1.88 1.88"/><path d="M14.12 3.88L16 2"/><path d="M9 7.13v-1a3.003 3.003 0 116 0v1"/><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 014-4h4a4 4 0 014 4v3c0 3.3-2.7 6-6 6"/><path d="M12 20v-9"/><path d="M6.53 9C4.6 8.8 3 7.1 3 5"/><path d="M6 13H2"/><path d="M3 21c0-2.1 1.7-3.9 3.8-4"/><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"/><path d="M22 13h-4"/><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"/>'}
                                {skillIcon(skill) === "cloud" && '<path d="M17.5 19H9a7 7 0 116.71-9h1.79a4.5 4.5 0 110 9z"/>'}
                                {skillIcon(skill) === "container" && '<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>'}
                                {skillIcon(skill) === "box" && '<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>'}
                                {skillIcon(skill) === "cog" && '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>'}
                                {skillIcon(skill) === "package" && '<line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>'}
                                {skillIcon(skill) === "database" && '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>'}
                                {skillIcon(skill) === "zap" && '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>'}
                                {skillIcon(skill) === "server" && '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>'}
                                {skillIcon(skill) === "layers" && '<polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/>'}
                                {skillIcon(skill) === "code" && '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>'}
                            </svg>
                            {skill}
                        </span>
                    ))}
                </div>
                <div class="mt-4 pt-4 border-t border-[#ECECEC]">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div class="flex items-center gap-3 text-xs text-[#9CA3AF]">
                            <span>Issued {issueDate}</span>
                            {expiration && <><span class="w-1 h-1 rounded-full bg-[#D1D5DB]"></span><span>Expires {expiration}</span></>}
                        </div>
                        <span class="btn-v2 inline-flex items-center gap-2 h-[52px] px-6 rounded-[16px] border-2 border-[#E5E7EB] text-[#111827] text-sm font-semibold transition-all duration-200 hover:border-[#EE0000] hover:bg-[rgba(238,0,0,.04)]">
                            Verify on Credly
                            <svg class="cta-arrow-v2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7m0 0H7m10 0v10"/></svg>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    )}
</a>
