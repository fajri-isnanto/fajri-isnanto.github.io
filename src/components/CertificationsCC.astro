---
import { ME } from '@/config';
import CertificationBadge from './CertificationBadge.astro';

const { certifications } = ME;
---

<div class="relative left-1/2 -translate-x-1/2 w-screen">
    <div class="max-w-[960px] mx-auto px-4">
        <div class="flex flex-col gap-10 text-n700 dark:text-n200 w-full mt-10">
            <div class="mb-4">
                <h2 class="text-3xl font-bold mb-2">Certifications</h2>
                <p class="text-sm text-gray-500">Verified credentials from Red Hat. Click any badge to verify on Credly.</p>
            </div>

            <div class="flex flex-col gap-6">
                {certifications.map((cert) => (
                    <CertificationBadge
                        badgeImage={cert.badgeImage}
                        title={cert.name}
                        issuer={cert.issuer}
                        description={cert.description}
                        tags={cert.skills}
                        issuedDate={cert.issueDate}
                        verifyUrl={cert.credlyUrl}
                    />
                ))}
            </div>
        </div>
    </div>
</div>
