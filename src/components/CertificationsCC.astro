---
import { ME } from '@/config';
import CertCardV2 from './CertCard.astro';
import CertCardV1 from './CertificationCardV2.astro';

const { certifications } = ME;
---

<div class="relative left-1/2 -translate-x-1/2 w-screen">
    <div class="max-w-7xl mx-auto px-4 mt-10">

        <!-- V2 -->
        <h2 class="text-2xl font-bold mb-1 text-[#111827]">V2 — Credly-Style (current)</h2>
        <p class="text-sm text-gray-500 mb-6">Badge 96px kiri, VERIFIED kanan atas, 2-col body + 3-col footer, 60% typography</p>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-16">
            {certifications.map((cert) => (
                <CertCardV2
                    badgeImage={cert.badgeImage}
                    title={cert.name}
                    issuer={cert.issuer}
                    description={cert.description}
                    tags={cert.skills}
                    issuedDate={cert.issueDate}
                    verifyUrl={cert.credlyUrl}
                />
            ))}
        </div>

        <!-- V1 -->
        <h2 class="text-2xl font-bold mb-1 text-[#111827]">V1 — Compact Grid (sebelumnya)</h2>
        <p class="text-sm text-gray-500 mb-6">Badge tengah, layout stack vertikal per card, 3 kolom compact</p>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {certifications.map((cert) => (
                <CertCardV1
                    compact={true}
                    title={cert.name}
                    vendor={cert.issuer}
                    description={cert.description}
                    badgeImage={cert.badgeImage}
                    verifyUrl={cert.credlyUrl}
                    issueDate={cert.issueDate}
                    skills={cert.skills}
                    verified={cert.verified}
                />
            ))}
        </div>

    </div>
</div>
