---
import { ME } from '@/config';
import CertCard from './CertCard.astro';

const { certifications } = ME;
---

<section class="certs-section">
    <div class="certs-section__inner">
        <h2 class="certs-section__title">Certifications</h2>
        <p class="certs-section__sub">Verified credentials from Red Hat. Click any badge to verify on Credly.</p>

        <div class="certs-section__grid">
            {certifications.map((cert) => (
                <CertCard
                    badgeImage={cert.badgeImage}
                    title={cert.name}
                    issuer={cert.issuer}
                    description={cert.description}
                    tags={cert.skills}
                    issuedDate={cert.issueDate}
                    verifyUrl={cert.credlyUrl}
                />
            ))}
        </div>
    </div>
</section>

<style>
    .certs-section {
        background: #f3f4f6;
        padding: 40px 0;
        width: 100%;
    }

    .certs-section__inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .certs-section__title {
        font-size: 32px;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0 0 6px 0;
    }

    .certs-section__sub {
        font-size: 15px;
        color: #5a6169;
        margin: 0 0 28px 0;
    }

    .certs-section__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    @media (max-width: 900px) {
        .certs-section__grid {
            grid-template-columns: 1fr;
        }
        .certs-section__title {
            font-size: 26px;
        }
    }
</style>
